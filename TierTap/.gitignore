CTT/.tmp-dd/
CTT/.asc-verify-dd/
CTT/.final-verify-dd/
CTT/.derivedData/
CTT/build/
CTT/**/*.xcarchive/
CTT/**/*.dSYM/
CTT/**/*.pcm
CTT/**/*.pack
CTT/**/*.idx
